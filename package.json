{
  "name": "toolbox",
  "version": "0.0.0",
  "description": "",
  "author": "kandynotkeo",
  "type": "module",
  "main": "index.js",
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/css": "1.1.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "validate": "npm run lint && npm run format",
    "change": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{html,md}": [
      "prettier --write"
    ]
  },
  "license": "ISC"
}
